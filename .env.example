# 记忆工程 v2.0 — 环境变量配置
# 复制为 .env 后填入你的密钥

# ─── API 密钥（必需） ───────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
GOOGLE_GEMINI_BASE_URL=your_proxy_base_url_here

# ─── 高德地图（可选，用于地址解析） ────────────────────────────
AMAP_API_KEY=your_amap_api_key_here

# ─── 飞书（可选，用于交互卡片与应用回调） ────────────────────────
FEISHU_APP_ID=your_feishu_app_id_here
FEISHU_APP_SECRET=your_feishu_app_secret_here
FEISHU_CALLBACK_VERIFICATION_TOKEN=
FEISHU_CALLBACK_ENCRYPT_KEY=
FEISHU_API_BASE_URL=https://open.feishu.cn
FEISHU_LONG_CONNECTION_LOG_LEVEL=INFO
FEISHU_DEFAULT_RECEIVE_ID=
FEISHU_DEFAULT_RECEIVE_ID_TYPE=open_id
FEISHU_APPROVAL_RECEIVE_ID=
FEISHU_APPROVAL_RECEIVE_ID_TYPE=chat_id
FEISHU_DIFFICULT_CASE_RECEIVE_ID=
FEISHU_DIFFICULT_CASE_RECEIVE_ID_TYPE=chat_id
REVIEW_BASE_URL=http://localhost:3000
REFLECTION_AGENT_PROVIDER=openrouter
REFLECTION_AGENT_OPENROUTER_API_KEY=
REFLECTION_AGENT_MODEL=
REFLECTION_AGENT_TEMPERATURE=0.1

# ─── 通用 ────────────────────────────────────────────────────────
APP_VERSION=v0317
DEFAULT_TASK_VERSION=v0317
MAX_PHOTOS=999999
SHOW_PROGRESS=true

# ─── 人脸识别（InsightFace + FAISS） ─────────────────────────────
# 默认使用工程内 vendor/face_recognition_src
FACE_RECOGNITION_SRC_PATH=
FACE_MODEL_NAME=buffalo_l
FACE_MAX_SIDE=1920
FACE_DET_THRESHOLD=0.60
FACE_SIM_THRESHOLD=0.50
FACE_MIN_SIZE=48
FACE_MATCH_TOP_K=5
FACE_MATCH_MARGIN_THRESHOLD=0.03
FACE_MATCH_WEAK_DELTA=0.055
FACE_MATCH_MIN_QUALITY_GRAY_ZONE=0.40
FACE_MATCH_HIGH_QUALITY_THRESHOLD=0.40
FACE_PROVIDERS=CPUExecutionProvider

# ─── MediaPipe 姿态估计 ─────────────────────────────────────────
FACE_LANDMARKS_ENABLED=true
FACE_LANDMARK_MODEL_PATH=
FACE_LANDMARK_MODEL_URL=https://storage.googleapis.com/mediapipe-models/face_landmarker/face_landmarker/float16/latest/face_landmarker.task
FACE_POSE_PROFILE_YAW_THRESHOLD=18.0
FACE_PROFILE_RESCUE_DELTA=0.04
FACE_PROFILE_RESCUE_MARGIN=0.02
FACE_PROFILE_RESCUE_MIN_QUALITY=0.40
FACE_SAME_PHOTO_MATCH_THRESHOLD=0.52

# 若已有 LFW benchmark 阈值文件，可在此指定
LFW_BENCHMARK_DIR=
FACE_MATCH_THRESHOLD_PATH=

# ─── VLM/LLM ────────────────────────────────────────────────────
GEMINI_MODEL=gemini-2.0-flash
