# API 配置文件示例
# 复制此文件为 .env 并填入你的配置

# ========================================
# 模式选择：官方 API vs 代理服务
# ========================================
# false: 直接调用官方 Gemini API
# true: 通过代理服务调用 Gemini
USE_API_PROXY=false

# ========================================
# 方案 1：官方 Gemini API
# ========================================
# 获取地址: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ========================================
# 方案 2：代理服务
# ========================================
API_PROXY_URL=https://your-proxy-host.example.com
API_PROXY_KEY=your_proxy_api_key_here
API_PROXY_MODEL=gemini-2.0-flash

# ========================================
# 地图与本地人脸项目
# ========================================
# 高德地图 API Key（可选）
AMAP_API_KEY=your_amap_api_key_here

# 本地 face-recognition 源码路径（可选，默认已写在 config.py）
FACE_RECOGNITION_SRC_PATH=/Users/ziyan/Documents/face-recognition/src
