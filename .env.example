# Memory Engineering environment template
# 复制本文件为 .env，然后把真实密钥和连接信息填进去

# ==================================================
# 基础运行
# ==================================================
APP_VERSION=v0317
DEFAULT_TASK_VERSION=v0317
MAX_UPLOAD_PHOTOS=5000

# ==================================================
# AI Provider / 地图 API
# ==================================================
# auto: 自动判断（若 key 形如 sk-... 会优先按 OpenRouter 处理）
# gemini: 强制直连 Gemini 官方 API
# proxy: 强制走自定义 Gemini 代理
# openrouter: 强制走 OpenRouter
MODEL_PROVIDER=auto

# false: 不使用自定义 Gemini 代理
# true: 通过代理服务调用 Gemini
USE_API_PROXY=false

# 官方 Gemini API Key
GEMINI_API_KEY=your_gemini_api_key_here

# OpenRouter 配置（如使用 OpenRouter，推荐填 OPENROUTER_API_KEY）
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_SITE_URL=http://localhost:3000
OPENROUTER_APP_NAME=Memory Engineering
OPENROUTER_VLM_MODEL=z-ai/glm-4.6v
OPENROUTER_LLM_MODEL=nvidia/nemotron-3-super-120b-a12b

# 代理服务配置
API_PROXY_URL=
API_PROXY_KEY=
API_PROXY_MODEL=gemini-2.0-flash

# 高德地图 API Key（可选）
AMAP_API_KEY=

# ==================================================
# Web / 后端服务
# ==================================================
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
# 如果平台只支持 PORT，也可以只填 PORT
PORT=8000
BACKEND_RELOAD=false
FRONTEND_ORIGIN=http://localhost:3000
CORS_ALLOW_ORIGINS=

AUTH_SESSION_COOKIE_NAME=memory_session
AUTH_SESSION_DAYS=14
HIGH_SECURITY_MODE=false
ALLOW_SELF_REGISTRATION=true
COOKIE_SECURE=false

# control-plane / worker
APP_ROLE=control-plane
WORKER_ORCHESTRATION_ENABLED=false

# ==================================================
# Worker 编排 / EC2
# ==================================================
AWS_REGION=
WORKER_LAUNCH_TEMPLATE_ID=
WORKER_LAUNCH_TEMPLATE_VERSION=$Default
WORKER_AMI_ID=
WORKER_INSTANCE_TYPE=
WORKER_IAM_INSTANCE_PROFILE=
WORKER_SECURITY_GROUP_ID=
WORKER_SUBNET_IDS=
WORKER_INSTANCE_NAME_PREFIX=memory-worker
WORKER_INTERNAL_PORT=9000
WORKER_SHARED_TOKEN=replace_with_a_long_random_secret
WORKER_TASK_ROOT=/mnt/secure-tasks
RESULT_TTL_HOURS=24
WORKER_POLL_SECONDS=3
WORKER_BOOT_TIMEOUT_SECONDS=300

# ==================================================
# 数据库
# ==================================================
# 本地预览默认会回落到 sqlite:///runtime/local_preview.db
DATABASE_URL=
SQL_ECHO=false

# Railway MySQL 兼容变量（可选，和 DATABASE_URL 二选一）
MYSQL_URL=
MYSQL_PUBLIC_URL=
MYSQLHOST=
MYSQLPORT=3306
MYSQLUSER=
MYSQLPASSWORD=
MYSQLDATABASE=

# ==================================================
# 对象存储 / S3 兼容
# ==================================================
# Railway Bucket 常会注入下面这些别名变量
BUCKET=
ENDPOINT=
REGION=ap-southeast-1
ACCESS_KEY_ID=
SECRET_ACCESS_KEY=

# 显式对象存储配置（可覆盖上面的别名）
OBJECT_STORAGE_BUCKET=
OBJECT_STORAGE_ENDPOINT=
OBJECT_STORAGE_REGION=ap-southeast-1
OBJECT_STORAGE_ACCESS_KEY_ID=
OBJECT_STORAGE_SECRET_ACCESS_KEY=
OBJECT_STORAGE_PREFIX=tasks
OBJECT_STORAGE_ADDRESSING_STYLE=auto

# 在 AWS 原生 S3 上，推荐只填写 bucket/region，让 ECS task role 或 EC2 instance profile 走默认凭证链：
# OBJECT_STORAGE_BUCKET=memory-engineering-artifacts
# OBJECT_STORAGE_REGION=ap-southeast-1

# ==================================================
# Frontend
# ==================================================
# 同域部署时通常留空
NEXT_PUBLIC_API_BASE_URL=

# ==================================================
# Face Recognition
# ==================================================
# 默认会使用仓库内 vendor/face_recognition_src
FACE_RECOGNITION_SRC_PATH=
FACE_MODEL_NAME=buffalo_l
FACE_MAX_SIDE=1920
FACE_DET_THRESHOLD=0.60
FACE_SIM_THRESHOLD=0.50
FACE_MIN_SIZE=48
FACE_MATCH_TOP_K=5
FACE_MATCH_MARGIN_THRESHOLD=0.03
FACE_MATCH_WEAK_DELTA=0.04
FACE_MATCH_MIN_QUALITY_GRAY_ZONE=0.40
FACE_MATCH_HIGH_QUALITY_THRESHOLD=0.40

LFW_BENCHMARK_DIR=
FACE_MATCH_THRESHOLD_PATH=

# 例如 CPUExecutionProvider 或 CUDAExecutionProvider,CPUExecutionProvider
FACE_PROVIDERS=CPUExecutionProvider
FACE_LANDMARKS_ENABLED=true
FACE_LANDMARK_MODEL_PATH=
FACE_LANDMARK_MODEL_URL=https://storage.googleapis.com/mediapipe-models/face_landmarker/face_landmarker/float16/latest/face_landmarker.task
FACE_POSE_PROFILE_YAW_THRESHOLD=18.0
FACE_PROFILE_RESCUE_DELTA=0.04
FACE_PROFILE_RESCUE_MARGIN=0.02
FACE_PROFILE_RESCUE_MIN_QUALITY=0.40
FACE_SAME_PHOTO_MATCH_THRESHOLD=0.52

# ==================================================
# Memory 外部存储
# ==================================================
# false: 只保留任务目录里的 preview / transparency 结果
# true: 同时发布到 Redis / Neo4j / Milvus
MEMORY_EXTERNAL_SINKS_ENABLED=false

# Redis
MEMORY_REDIS_URL=
MEMORY_REDIS_PREFIX=memory

# Neo4j
MEMORY_NEO4J_URI=
MEMORY_NEO4J_USERNAME=neo4j
MEMORY_NEO4J_PASSWORD=
MEMORY_NEO4J_DATABASE=neo4j

# Milvus
MEMORY_MILVUS_URI=
MEMORY_MILVUS_USER=
MEMORY_MILVUS_PASSWORD=
MEMORY_MILVUS_TOKEN=
MEMORY_MILVUS_DB_NAME=
MEMORY_MILVUS_COLLECTION=memory_segments
MEMORY_MILVUS_VECTOR_DIM=512
MEMORY_REAL_EMBEDDINGS_ENABLED=false
MEMORY_EMBEDDING_PROVIDER=auto
MEMORY_EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
MEMORY_EMBEDDING_VERSION=v1
MEMORY_EMBEDDING_TIMEOUT_SECONDS=30
