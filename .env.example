# API 配置文件示例
# 复制此文件为 .env 并填入你的配置

# ========================================
# 模式选择：官方 API vs 代理服务
# ========================================
# false: 直接调用官方 Gemini API
# true: 通过代理服务调用 Gemini
USE_API_PROXY=false

# ========================================
# 方案 1：官方 Gemini API
# ========================================
# 获取地址: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ========================================
# 方案 2：代理服务
# ========================================
API_PROXY_URL=https://your-proxy-host.example.com
API_PROXY_KEY=your_proxy_api_key_here
API_PROXY_MODEL=gemini-2.0-flash

# ========================================
# 地图与本地人脸项目
# ========================================
# 高德地图 API Key（可选）
AMAP_API_KEY=your_amap_api_key_here

# ========================================
# EC2 / 通用生产部署
# ========================================
FRONTEND_ORIGIN=https://memory.example.com
HIGH_SECURITY_MODE=false
ALLOW_SELF_REGISTRATION=true
COOKIE_SECURE=true
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000
BACKEND_RELOAD=false
APP_ROLE=control-plane
WORKER_ORCHESTRATION_ENABLED=false
AWS_REGION=
WORKER_LAUNCH_TEMPLATE_ID=
WORKER_LAUNCH_TEMPLATE_VERSION=$Default
WORKER_AMI_ID=
WORKER_INSTANCE_TYPE=
WORKER_IAM_INSTANCE_PROFILE=
WORKER_SECURITY_GROUP_ID=
WORKER_SUBNET_IDS=
WORKER_INSTANCE_NAME_PREFIX=memory-worker
WORKER_INTERNAL_PORT=9000
WORKER_SHARED_TOKEN=replace_with_a_long_random_secret
WORKER_TASK_ROOT=/mnt/secure-tasks
RESULT_TTL_HOURS=24
WORKER_POLL_SECONDS=3
WORKER_BOOT_TIMEOUT_SECONDS=300

# face-recognition 源码路径（可选）
# 默认使用仓库内置的 vendor/face_recognition_src
# FACE_RECOGNITION_SRC_PATH=/absolute/path/to/face-recognition/src

# 后端数据库
# 本地预览可不填，默认回落到 sqlite:///runtime/local_preview.db
# Railway + MySQL 推荐写法：
# DATABASE_URL=${{MySQL.MYSQL_URL}}
# EC2 单机也可以显式写：
# DATABASE_URL=sqlite:////opt/memory_engineering/runtime/local_preview.db

# Railway Bucket / S3 兼容对象存储
# Railway 挂载 Bucket 后通常会自动注入以下变量：
# BUCKET=...
# ENDPOINT=...
# REGION=...
# ACCESS_KEY_ID=...
# SECRET_ACCESS_KEY=...
#
# 如需手动覆盖，可使用下面这些变量：
# OBJECT_STORAGE_BUCKET=...
# OBJECT_STORAGE_ENDPOINT=...
# OBJECT_STORAGE_REGION=auto
# OBJECT_STORAGE_ACCESS_KEY_ID=...
# OBJECT_STORAGE_SECRET_ACCESS_KEY=...
# OBJECT_STORAGE_PREFIX=tasks
# OBJECT_STORAGE_ADDRESSING_STYLE=auto

# 前端
# 同域部署到 Nginx 时建议留空，这样浏览器直接请求当前域名下的 /api
# NEXT_PUBLIC_API_BASE_URL=
