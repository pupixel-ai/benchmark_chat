# API 配置文件模板
# 复制此文件为 .env 并填入你的 API Key

# ========================================
# 模式选择：官方 API vs 代理服务
# ========================================
# 选择 false 使用官方 Gemini API
# 选择 true 使用代理服务

USE_API_PROXY=true

# ========================================
# 方案 1：官方 Gemini API (USE_API_PROXY=false)
# ========================================
# 获取地址: https://makersuite.google.com/app/apikey
# 1. 访问上面的链接
# 2. 点击 "Create API Key" 或使用现有的
# 3. 复制 API Key
# 4. 粘贴到下面

GEMINI_API_KEY=your_gemini_api_key_here

# ========================================
# 方案 2：代理服务 (USE_API_PROXY=true)
# ========================================
# 代理服务的基础 URL（包括协议和域名，不包括路径）
# 例如: https://ai-platform-proxy.onrender.com

API_PROXY_URL=https://your-proxy-host.example.com

# 代理服务的 API Key（通常在请求头中作为 x-api-key）
API_PROXY_KEY=your_proxy_api_key_here

# 代理支持的模型名称（根据代理服务支持的模型调整）
# 常见值: gemini-2.0-flash, gemini-1.5-pro, gemini-1.5-flash
API_PROXY_MODEL=gemini-2.0-flash

# ========================================
# 高德地图 API 密钥 (可选)
# ========================================
# 用于GPS坐标反向地理编码（获取地址）
# 获取地址: https://console.amap.com/dev/key/app
AMAP_API_KEY=your_amap_api_key_here

# EC2 / 通用生产部署
FRONTEND_ORIGIN=https://memory.example.com
COOKIE_SECURE=true
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000
BACKEND_RELOAD=false

# 数据库配置
# 本地预览可以不填；Railway 上推荐直接引用 MySQL service 变量
# DATABASE_URL=${{MySQL.MYSQL_URL}}
# EC2 单机也可以显式写：
# DATABASE_URL=sqlite:////opt/memory_engineering/runtime/local_preview.db

# 如需覆盖仓库内置的人脸识别源码路径，可显式指定
# FACE_RECOGNITION_SRC_PATH=/absolute/path/to/face-recognition/src

# Railway Bucket / S3 兼容对象存储
# BUCKET=
# ENDPOINT=
# REGION=auto
# ACCESS_KEY_ID=
# SECRET_ACCESS_KEY=
# OBJECT_STORAGE_PREFIX=tasks
# OBJECT_STORAGE_ADDRESSING_STYLE=auto

# 前端
# 同域部署到 Nginx 时建议留空
# NEXT_PUBLIC_API_BASE_URL=
