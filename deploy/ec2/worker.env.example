APP_ROLE=worker
HIGH_SECURITY_MODE=true
ALLOW_SELF_REGISTRATION=false
USE_API_PROXY=false
GEMINI_API_KEY=
AMAP_API_KEY=

# Worker 只接受 control-plane 的内网调用，不直接面向浏览器。
FRONTEND_ORIGIN=https://control.example.com
COOKIE_SECURE=true
BACKEND_HOST=0.0.0.0
BACKEND_PORT=9000
BACKEND_RELOAD=false

WORKER_ORCHESTRATION_ENABLED=false
WORKER_INTERNAL_PORT=9000
WORKER_SHARED_TOKEN=replace_with_a_long_random_secret
WORKER_TASK_ROOT=/mnt/secure-tasks

# Worker 自己不负责启动别的 worker，但为了保持配置结构一致，保留这些键。
AWS_REGION=
WORKER_LAUNCH_TEMPLATE_ID=
WORKER_LAUNCH_TEMPLATE_VERSION=$Default
WORKER_AMI_ID=
WORKER_INSTANCE_TYPE=
WORKER_IAM_INSTANCE_PROFILE=
WORKER_SECURITY_GROUP_ID=
WORKER_SUBNET_IDS=
WORKER_INSTANCE_NAME_PREFIX=memory-worker
RESULT_TTL_HOURS=24
WORKER_POLL_SECONDS=3
WORKER_BOOT_TIMEOUT_SECONDS=300

# Worker 本机只保存最少的运行状态；敏感图片保存在 instance store。
DATABASE_URL=sqlite:////opt/memory_engineering/runtime/worker-local.db
