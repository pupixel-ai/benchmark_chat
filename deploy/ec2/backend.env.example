USE_API_PROXY=false
GEMINI_API_KEY=your_gemini_api_key_here
AMAP_API_KEY=your_amap_api_key_here

FRONTEND_ORIGIN=https://memory.example.com
HIGH_SECURITY_MODE=false
ALLOW_SELF_REGISTRATION=true
COOKIE_SECURE=true
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000
BACKEND_RELOAD=false
APP_ROLE=control-plane
WORKER_ORCHESTRATION_ENABLED=false
AWS_REGION=
WORKER_LAUNCH_TEMPLATE_ID=
WORKER_LAUNCH_TEMPLATE_VERSION=$Default
# 如果不用 Launch Template，也可以改为直接填写下面这些
# WORKER_AMI_ID=ami-xxxxxxxx
# WORKER_INSTANCE_TYPE=i4i.large
# WORKER_IAM_INSTANCE_PROFILE=memory-worker-profile
# WORKER_SECURITY_GROUP_ID=sg-xxxxxxxx
# WORKER_SUBNET_IDS=subnet-aaa,subnet-bbb
WORKER_INSTANCE_NAME_PREFIX=memory-worker
WORKER_INTERNAL_PORT=9000
WORKER_SHARED_TOKEN=replace_with_a_long_random_secret
WORKER_TASK_ROOT=/mnt/secure-tasks
RESULT_TTL_HOURS=24
WORKER_POLL_SECONDS=3
WORKER_BOOT_TIMEOUT_SECONDS=300

# Kafka 终态推送（独立 publisher 进程复用同一份配置）
KAFKA_ENABLED=false
KAFKA_BOOTSTRAP_SERVERS=
KAFKA_TERMINAL_TOPIC=prod.memory.task.terminal.v1
KAFKA_CLIENT_ID=memory-engineering-terminal-publisher
KAFKA_MESSAGE_MAX_BYTES=819200
KAFKA_PUBLISHER_BATCH_SIZE=20
KAFKA_PUBLISHER_POLL_SECONDS=2
KAFKA_PUBLISHER_RETRY_SECONDS=10
KAFKA_PUBLISHER_LOCK_SECONDS=60
# 如需 SASL / TLS，再补下面几项
# KAFKA_SECURITY_PROTOCOL=SASL_SSL
# KAFKA_SASL_MECHANISM=SCRAM-SHA-512
# KAFKA_SASL_USERNAME=
# KAFKA_SASL_PASSWORD=

# 单机部署建议先用 SQLite，后续再换 RDS MySQL
DATABASE_URL=sqlite:////opt/memory_engineering/runtime/local_preview.db

# 如需使用代理模式，打开下面三项并将 USE_API_PROXY 改为 true
# API_PROXY_URL=https://your-proxy-host.example.com
# API_PROXY_KEY=your_proxy_api_key_here
# API_PROXY_MODEL=gemini-2.0-flash

# 如需启用对象存储，填写下面参数
# OBJECT_STORAGE_BUCKET=your-bucket
# OBJECT_STORAGE_ENDPOINT=https://s3.ap-southeast-1.amazonaws.com
# OBJECT_STORAGE_REGION=ap-southeast-1
# OBJECT_STORAGE_ACCESS_KEY_ID=your_access_key
# OBJECT_STORAGE_SECRET_ACCESS_KEY=your_secret_key
# OBJECT_STORAGE_PREFIX=tasks
# OBJECT_STORAGE_ADDRESSING_STYLE=auto
