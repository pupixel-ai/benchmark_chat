APP_ROLE=control-plane
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_RELOAD=false
FRONTEND_ORIGIN=https://memory.example.com
COOKIE_SECURE=true
HIGH_SECURITY_MODE=false
ALLOW_SELF_REGISTRATION=true

DATABASE_URL=mysql+pymysql://memory_app:change-me@memory-db.cluster-xxxx.ap-southeast-1.rds.amazonaws.com:3306/memory_engineering
SQL_ECHO=false

OBJECT_STORAGE_BUCKET=memory-engineering-artifacts
OBJECT_STORAGE_REGION=ap-southeast-1
OBJECT_STORAGE_PREFIX=tasks

AWS_REGION=ap-southeast-1
WORKER_ORCHESTRATION_ENABLED=true
WORKER_LAUNCH_TEMPLATE_ID=lt-xxxxxxxx
WORKER_LAUNCH_TEMPLATE_VERSION=$Default
WORKER_INSTANCE_NAME_PREFIX=memory-worker
WORKER_INTERNAL_PORT=9000
WORKER_SHARED_TOKEN=replace_with_a_long_random_secret
WORKER_TASK_ROOT=/mnt/secure-tasks
RESULT_TTL_HOURS=24
WORKER_POLL_SECONDS=3
WORKER_BOOT_TIMEOUT_SECONDS=300

MODEL_PROVIDER=bedrock
VLM_PROVIDER=openrouter
LLM_PROVIDER=openrouter
BEDROCK_REGION=ap-southeast-1
BEDROCK_VLM_MODEL_PRIMARY=amazon.nova-pro-v1:0
BEDROCK_VLM_MODEL_FALLBACK=amazon.nova-pro-v1:0
BEDROCK_VLM_MODEL_POLICY=primary
BEDROCK_LLM_MODEL=anthropic.claude-sonnet-4-6
OPENROUTER_API_KEY=
OPENROUTER_VLM_MODEL=google/gemini-3.1-flash-lite-preview
OPENROUTER_LLM_MODEL=nvidia/nemotron-3-super-120b-a12b
AMAP_API_KEY=

MEMORY_EXTERNAL_SINKS_ENABLED=true
MEMORY_REDIS_URL=redis://memory-redis.xxxxxx.cache.amazonaws.com:6379/0
MEMORY_REDIS_PREFIX=memory
MEMORY_NEO4J_URI=neo4j://10.0.20.10:7687
MEMORY_NEO4J_USERNAME=neo4j
MEMORY_NEO4J_PASSWORD=change-me
MEMORY_NEO4J_DATABASE=neo4j
MEMORY_MILVUS_URI=http://10.0.30.10:19530
MEMORY_MILVUS_COLLECTION=memory_segments
MEMORY_MILVUS_VECTOR_DIM=512
MEMORY_REAL_EMBEDDINGS_ENABLED=true
MEMORY_EMBEDDING_PROVIDER=fastembed
MEMORY_EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
MEMORY_EMBEDDING_VERSION=v1
